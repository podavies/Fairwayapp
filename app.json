{
  "expo": {
    "name": "Missfits Rollup Golf Calculator",
    "slug": "fairway-mobile",
    "version": "2.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f4efe1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Missfits Rollup Golf Calculator to access your photos so you can attach scorecard images.",
          "cameraPermission": "Allow Missfits Rollup Golf Calculator to use your camera so you can scan a scorecard image.",
          "microphonePermission": false
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.podavies.fairway",
      "buildNumber": "19",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f2f2f2"
      }
    },
    "extra": {
      "eas": {
        "projectId": "f49a1ebc-099c-4d21-9613-ae8dc2d5998b"
      }
    }
  }
}
