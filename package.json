{
  "name": "fairway-mobile",
  "version": "2.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test:totals": "node --test .\\tests\\score-entry-totals.test.mjs",
    "test:ocr": "node --test .\\tests\\scorecard-ocr.test.mjs",
    "test:iphone": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-iphone-test.ps1",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production",
    "testflight": "npx testflight"
  },
  "dependencies": {
    "expo": "^54.0.0",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "^19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  }
}
